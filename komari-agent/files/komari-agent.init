#!/bin/sh /etc/rc.common

# Komari Agent init script for OpenWrt/LEDE procd
# Reads configuration from UCI (/etc/config/komari-agent)

START=99
STOP=10

USE_PROCD=1

PROG="/usr/bin/komari-agent"

start_service() {
	config_load komari-agent

	# Check master enable switch
	local enabled
	config_get_bool enabled main enabled 0
	[ "$enabled" -ne 1 ] && {
		logger -t komari-agent "Service is disabled (komari-agent.main.enabled=0)"
		return 0
	}

	# Check required parameters
	local endpoint token
	config_get endpoint main endpoint ''
	config_get token main token ''

	[ -z "$endpoint" ] && {
		logger -t komari-agent "Endpoint not configured, refusing to start"
		return 0
	}
	[ -z "$token" ] && {
		logger -t komari-agent "Token not configured, refusing to start"
		return 0
	}

	# Verify binary exists
	[ ! -x "$PROG" ] && {
		logger -t komari-agent "Binary not found at $PROG"
		return 1
	}

	# Build command-line arguments
	local args
	args="-e $endpoint -t $token"

	# Numeric parameters - only passed when explicitly set.
	# The agent has its own built-in defaults, so we don't pass these
	# unless the user configured a value in UCI.
	local interval month_rotate
	config_get interval main interval ''
	config_get month_rotate main month_rotate ''

	if [ -n "$interval" ]; then
		case "$interval" in
			*[!0-9]*)
				logger -t komari-agent "Invalid interval '$interval', ignoring"
				;;
			*)
				args="$args -i $interval"
				;;
		esac
	fi

	if [ -n "$month_rotate" ]; then
		case "$month_rotate" in
			*[!0-9]*)
				logger -t komari-agent "Invalid month_rotate '$month_rotate', ignoring"
				;;
			*)
				# Clamp to valid range 1-31
				[ "$month_rotate" -lt 1 ] && month_rotate=1
				[ "$month_rotate" -gt 31 ] && month_rotate=31
				args="$args --month-rotate $month_rotate"
				;;
		esac
	fi

	# Boolean feature flags
	local disable_web_ssh ignore_unsafe_cert get_ip_from_nic
	local disable_auto_update memory_include_cache gpu

	config_get_bool disable_web_ssh main disable_web_ssh 0
	config_get_bool ignore_unsafe_cert main ignore_unsafe_cert 0
	config_get_bool get_ip_from_nic main get_ip_from_nic 0
	config_get_bool disable_auto_update main disable_auto_update 0
	config_get_bool memory_include_cache main memory_include_cache 0
	config_get_bool gpu main gpu 0

	[ "$disable_web_ssh" -eq 1 ] && args="$args --disable-web-ssh"
	[ "$ignore_unsafe_cert" -eq 1 ] && args="$args --ignore-unsafe-cert"
	[ "$get_ip_from_nic" -eq 1 ] && args="$args --get-ip-addr-from-nic"
	[ "$disable_auto_update" -eq 1 ] && args="$args --disable-auto-update"
	[ "$memory_include_cache" -eq 1 ] && args="$args --memory-include-cache"
	[ "$gpu" -eq 1 ] && args="$args --gpu"

	# Include/exclude NICs (UCI list -> comma-separated string)
	local include_nics exclude_nics
	config_get include_nics main include_nics ''
	config_get exclude_nics main exclude_nics ''

	if [ -n "$include_nics" ]; then
		# Convert space-separated UCI list to comma-separated
		local nic_list
		nic_list=$(echo "$include_nics" | tr -s ' ' | sed 's/ /,/g' | sed 's/^,//;s/,$//')
		[ -n "$nic_list" ] && args="$args --include-nics $nic_list"
	fi

	if [ -n "$exclude_nics" ]; then
		local nic_list
		nic_list=$(echo "$exclude_nics" | tr -s ' ' | sed 's/ /,/g' | sed 's/^,//;s/,$//')
		[ -n "$nic_list" ] && args="$args --exclude-nics $nic_list"
	fi

	# Include mount points (UCI list -> semicolon-separated string)
	local include_mountpoint
	config_get include_mountpoint main include_mountpoint ''

	if [ -n "$include_mountpoint" ]; then
		local mp_list
		mp_list=$(echo "$include_mountpoint" | tr -s ' ' | sed 's/ /;/g' | sed 's/^;//;s/;$//')
		[ -n "$mp_list" ] && args="$args --include-mountpoint $mp_list"
	fi

	logger -t komari-agent "Starting with args: $args"

	# Start procd service instance
	procd_open_instance
	procd_set_param command $PROG $args
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param user root
	procd_set_param pidfile /var/run/komari-agent.pid
	procd_set_param limits core="unlimited"
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_config_trigger "config.change" "komari-agent" /etc/init.d/komari-agent reload
}
